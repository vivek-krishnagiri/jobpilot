# JobPilot — environment variables
#
# JobPilot is fully local-first and does NOT require any API keys or secrets
# by default. All data is stored in server/data/ (SQLite + uploaded files).
#
# Copy this file to .env if you ever need to override defaults.
# Currently no variables are required to run the app.

# (reserved for future use — e.g. PORT overrides)
# SERVER_PORT=3001
# RUNNER_PORT=3002
