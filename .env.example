# JobPilot — environment variables
#
# JobPilot is fully local-first and does NOT require any API keys or secrets
# by default. All data is stored in server/data/ (SQLite + uploaded files).
#
# Copy this file to .env (in the server/ directory or project root) if you
# want to override any of the defaults below.

# ─── Authentication ────────────────────────────────────────────────────────────

# Secret used to sign session tokens. Change this in any non-local deployment.
# The server uses an in-memory session store; a restart clears all sessions.
# SESSION_SECRET=change-me-in-production

# Default user credentials created on first server startup.
# These are hashed with bcrypt before storage — never stored in plaintext.
# DEFAULT_USER_USERNAME=vivek
# DEFAULT_USER_PASSWORD=chess123

# ─── Ports (optional) ─────────────────────────────────────────────────────────

# SERVER_PORT=3001
# RUNNER_PORT=3002
