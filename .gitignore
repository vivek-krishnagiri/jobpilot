# ─── Dependencies ─────────────────────────────────────────────────────────────
**/node_modules/

# ─── Build output ─────────────────────────────────────────────────────────────
**/dist/
**/build/
client/dist/

# ─── Local data (DB, uploads) — never commit ──────────────────────────────────
server/data/

# ─── Environment variables ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*

# ─── Playwright ───────────────────────────────────────────────────────────────
playwright-report/
test-results/
/playwright/.cache/

# ─── OS junk ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editor ───────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ─── TypeScript cache ─────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── Temp ─────────────────────────────────────────────────────────────────────
tmp/
.tmp/
